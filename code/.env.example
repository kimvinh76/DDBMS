PORT=3000
MOCK_MODE=true
# ============================================================================
# CẤU HÌNH KẾT NỐI SQL SERVER 

# Cách sử dụng: Sao chép file này thành .env và điều chỉnh theo IP, Port, User, Password của máy bạn
# Mỗi chi nhánh/trung tâm có database riêng, kết nối qua các cổng khác nhau


# HUE - Port 1401 (Chi nhánh Huế)

# HUE_DB_HOST: Địa chỉ IP hoặc hostname của server SQL Server chứa dữ liệu Huế
# HUE_DB_PORT: Cổng kết nối (mặc định SQL Server là 1433, đây chúng ta dùng 1401)
# HUE_DB_USER: Tên người dùng SQL Server (thường là 'sa' hoặc tài khoản khác)
# HUE_DB_PASSWORD: Mật khẩu SQL Server
# HUE_DB_NAME: Tên database chứa dữ liệu Huế (Store_H)
HUE_DB_HOST=localhost
HUE_DB_PORT=1401
HUE_DB_USER=sa
HUE_DB_PASSWORD=YourStrong(!)Password
HUE_DB_NAME=Store_H

# ============================================================================
# SAIGON - Port 1402 (Chi nhánh Sài Gòn)

# Cấu trúc tương tự HUE, nhưng kết nối đến database Sài Gòn
SAIGON_DB_HOST=localhost
SAIGON_DB_PORT=1402
SAIGON_DB_USER=sa
SAIGON_DB_PASSWORD=YourStrong(!)Password
SAIGON_DB_NAME=Store_SG

# ============================================================================
# HANOI - Port 1403 (Chi nhánh Hà Nội)

# Cấu trúc tương tự HUE, nhưng kết nối đến database Hà Nội
HANOI_DB_HOST=localhost
HANOI_DB_PORT=1403
HANOI_DB_USER=sa
HANOI_DB_PASSWORD=YourStrong(!)Password
HANOI_DB_NAME=Store_HN

# ============================================================================
# CENTRAL - Port 1404 (Trung tâm)

# Database trung tâm quản lý: sản phẩm gốc, nhân viên trung tâm, điều chuyển kho

CENTRAL_DB_HOST=localhost
CENTRAL_DB_PORT=1404
CENTRAL_DB_USER=sa
CENTRAL_DB_PASSWORD=YourStrong(!)Password
CENTRAL_DB_NAME=CentralDB


LINKED_HUE=HUE_SERVER
LINKED_SAIGON=SG_SERVER
LINKED_HANOI=HN_SERVER



READONLY_USE_SP=1


EMPLOYEE_WRITE_USE_SP=0


INVENTORY_IMPORT_USE_SP=0


INVOICE_CREATE_USE_SP=0


INVOICE_CREATE_SP_BRANCHES=HUE,SAIGON,HANOI
